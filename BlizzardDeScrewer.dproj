<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Base>True</Base>
    <AppType>Application</AppType>
    <Config Condition="'$(Config)'==''">Debug</Config>
    <FrameworkType>VCL</FrameworkType>
    <MainSource>BlizzardDeScrewer.dpr</MainSource>
    <Platform Condition="'$(Platform)'==''">Win32</Platform>
    <ProjectGuid>{19D67F4E-49C5-4F47-B479-ABDFD305599E}</ProjectGuid>
    <ProjectName Condition="'$(ProjectName)'==''">BlizzardDeScrewer</ProjectName>
    <ProjectVersion>20.4</ProjectVersion>
    <TargetedPlatforms>1</TargetedPlatforms>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
    <Base>true</Base>
  </PropertyGroup>
  <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
    <Base_Win32>true</Base_Win32>
    <CfgParent>Base</CfgParent>
    <Base>true</Base>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
    <Cfg_1>true</Cfg_1>
    <CfgParent>Base</CfgParent>
    <Base>true</Base>
  </PropertyGroup>
  <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win32)'!=''">
    <Cfg_1_Win32>true</Cfg_1_Win32>
    <CfgParent>Cfg_1</CfgParent>
    <Cfg_1>true</Cfg_1>
    <Base>true</Base>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
    <Cfg_2>true</Cfg_2>
    <CfgParent>Base</CfgParent>
    <Base>true</Base>
  </PropertyGroup>
  <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_2)'=='true') or '$(Cfg_2_Win32)'!=''">
    <Cfg_2_Win32>true</Cfg_2_Win32>
    <CfgParent>Cfg_2</CfgParent>
    <Cfg_2>true</Cfg_2>
    <Base>true</Base>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Base)'!=''">
    <SanitizedProjectName>BlizzardDeScrewer</SanitizedProjectName>
    <Custom_Styles>"Amakrits|VCLSTYLE|$(BDSCOMMONDIR)\Styles\Amakrits 9.vsf"</Custom_Styles>
    <DCC_Alignment>2</DCC_Alignment>
    <DCC_DUPLICATE_CTOR_DTOR>false</DCC_DUPLICATE_CTOR_DTOR>
    <DCC_DcuOutput>$(ProductVersion)_$(Platform)_$(Config)</DCC_DcuOutput>
    <DCC_ExeOutput>.\</DCC_ExeOutput>
    <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
    <DCC_MapFile>3</DCC_MapFile>
    <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Vcl;Vcl.Imaging;Vcl.Touch;Vcl.Samples;Vcl.Shell;$(DCC_Namespace)</DCC_Namespace>
    <DCC_UnitSearchPath>c:\Projects\LightSaber\FrameVCL\;c:\Projects\LightSaber\;c:\Projects\LightSaber\FrameVCL\AutoTranslator\;c:\Projects\LightSaber\External\;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
    <Icon_MainIcon>$(BDS)\bin\delphi_PROJECTICON.ico</Icon_MainIcon>
    <Manifest_File>$(BDS)\bin\default_app.manifest</Manifest_File>
    <VerInfo_AutoIncVersion>true</VerInfo_AutoIncVersion>
    <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
    <VerInfo_Keys>CompanyName=BuyTime Ltd;FileDescription=Blizzard DeScrewer - Battle.net cleanup utility;FileVersion=1.0.0.0;InternalName=BlizzardDeScrewer;LegalCopyright=Gabriel Moraru;LegalTrademarks=Gabriel Moraru;OriginalFilename=BlizzardDeScrewer.exe;ProductName=Blizzard DeScrewer;ProductVersion=1.0.0.0;Comments=Fixes Battle.net installer stuck at 45%;CFBundleName=</VerInfo_Keys>
    <VerInfo_Locale>1033</VerInfo_Locale>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Base_Win32)'!=''">
    <BT_BuildType>Debug</BT_BuildType>
    <DCC_Namespace>Winapi;System.Win;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;Bde;$(DCC_Namespace)</DCC_Namespace>
    <DCC_UsePackage>vcl;rtl;vclie;$(DCC_UsePackage)</DCC_UsePackage>
    <Manifest_File>$(BDS)\bin\default_app.manifest</Manifest_File>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Cfg_1)'!=''">
    <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
    <DCC_IntegerOverflowCheck>true</DCC_IntegerOverflowCheck>
    <DCC_MapFile>3</DCC_MapFile>
    <DCC_Optimize>false</DCC_Optimize>
    <DCC_RangeChecking>true</DCC_RangeChecking>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Cfg_1_Win32)'!=''">
    <AppDPIAwarenessMode>PerMonitorV2</AppDPIAwarenessMode>
    <DCC_RemoteDebug>false</DCC_RemoteDebug>
    <VerInfo_Build>13</VerInfo_Build>
    <VerInfo_Keys>CompanyName=BuyTime Ltd;FileDescription=Blizzard DeScrewer - Battle.net cleanup utility;FileVersion=1.0.0.13;InternalName=BlizzardDeScrewer;LegalCopyright=Gabriel Moraru;LegalTrademarks=Gabriel Moraru;OriginalFilename=BlizzardDeScrewer.exe;ProductName=Blizzard DeScrewer;ProductVersion=1.0.0.0;Comments=Fixes Battle.net installer stuck at 45%;CFBundleName=</VerInfo_Keys>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Cfg_2)'!=''">
    <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
    <DCC_IntegerOverflowCheck>false</DCC_IntegerOverflowCheck>
    <DCC_RangeChecking>false</DCC_RangeChecking>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Cfg_2_Win32)'!=''">
    <AppDPIAwarenessMode>PerMonitorV2</AppDPIAwarenessMode>
  </PropertyGroup>
  <ItemGroup>
    <DelphiCompile Include="$(MainSource)">
      <MainSource>MainSource</MainSource>
    </DelphiCompile>
    <DCCReference Include="FormMain.pas">
      <Form>MainForm</Form>
      <FormType>dfm</FormType>
    </DCCReference>
    <DCCReference Include="uInitialization.pas" />
    <DCCReference Include="..\..\LightSaber\FrameVCL\LightVcl.Visual.AppData.pas" />
    <DCCReference Include="..\..\LightSaber\LightCore.AppData.pas" />
    <DCCReference Include="..\..\LightSaber\FrameVCL\AutoTranslator\FormTranslSelector.pas" />
    <DCCReference Include="..\..\LightSaber\FrameVCL\AutoTranslator\FormTranslEditor.pas" />
    <DCCReference Include="..\..\LightSaber\FrameVCL\AutoTranslator\LightVcl.TranslatorAPI.pas" />
    <BuildConfiguration Include="Base">
      <Key>Base</Key>
    </BuildConfiguration>
    <BuildConfiguration Include="Debug">
      <Key>Cfg_1</Key>
      <CfgParent>Base</CfgParent>
    </BuildConfiguration>
    <BuildConfiguration Include="Release">
      <Key>Cfg_2</Key>
      <CfgParent>Base</CfgParent>
    </BuildConfiguration>
  </ItemGroup>
  <ProjectExtensions>
    <Borland.Personality>Delphi.Personality.12</Borland.Personality>
    <Borland.ProjectType>Application</Borland.ProjectType>
    <BorlandProject>
      <Delphi.Personality>
