  object grpCleanup: TGroupBox
    AlignWithMargins = True
    Left = 3
    Top = 3
    Width = 475
    Height = 585
    Align = alLeft
    Caption = ' Cleanup Steps '
    TabOrder = 0
    DesignSize = (
      475
      585)
    object chkKillProc: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 23
      Width = 465
      Height = 17
      Hint = 
        'Terminates all running Blizzard processes so their files can be ' +
        'deleted'
      Align = alTop
      Caption = 
        'Kill Blizzard processes (Battle.net.exe, Agent.exe, BlizzardErro' +
        'r.exe)'
      Checked = True
      State = cbChecked
      TabOrder = 0
    end
    object chkRegHKCU: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 46
      Width = 465
      Height = 17
      Hint = 'Removes current user Blizzard settings from the registry'
      Align = alTop
      Caption = 'Delete registry: HKCU\Software\Blizzard Entertainment'
      Checked = True
      State = cbChecked
      TabOrder = 1
    end
    object chkRegHKLM: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 69
      Width = 465
      Height = 17
      Hint = 
        'Removes machine-wide Blizzard settings from the registry (requir' +
        'es admin)'
      Align = alTop
      Caption = 
        'Delete registry: HKLM\SOFTWARE\WOW6432Node\Blizzard Entertainmen' +
        't'
      Checked = True
      State = cbChecked
      TabOrder = 2
    end
    object chkBattleNet: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 92
      Width = 465
      Height = 17
      Hint = 'Battle.net launcher configuration and cache data'
      Align = alTop
      Caption = 'Delete C:\ProgramData\Battle.net'
      Checked = True
      State = cbChecked
      TabOrder = 3
    end
    object chkBNetComp: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 115
      Width = 465
      Height = 17
      Hint = 'Battle.net shared components and update agent files'
      Align = alTop
      Caption = 'Delete C:\ProgramData\Battle.net_components'
      Checked = True
      State = cbChecked
      TabOrder = 4
    end
    object chkBlizzard: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 138
      Width = 465
      Height = 17
      Hint = 'Blizzard shared game data and crash report files'
      Align = alTop
      Caption = 'Delete C:\ProgramData\Blizzard Entertainment'
      Checked = True
      State = cbChecked
      TabOrder = 5
    end
    object chkLocalApp: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 184
      Width = 465
      Height = 17
      Hint = 
        'Per-user Blizzard cache and temporary files in your AppData\Loca' +
        'l folder'
      Align = alTop
      Caption = 'Delete %LOCALAPPDATA%\Blizzard Entertainment'
      Checked = True
      State = cbChecked
      TabOrder = 7
    end
    object chkRoamingApp: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 207
      Width = 465
      Height = 17
      Hint = 
        'Per-user Battle.net cache in your AppData\Roaming folder. Often ' +
        'missed during manual cleanup.'
      Align = alTop
      Caption = 'Delete %APPDATA%\Battle.net'
      Checked = True
      State = cbChecked
      TabOrder = 16
    end
    object chkDocuments: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 230
      Width = 465
      Height = 17
      Hint = 
        'WARNING: This folder contains your replays, saved games, and pla' +
        'yer profiles! Unchecked by default for safety.'
      Align = alTop
      Caption = 'Delete Documents\StarCraft II (contains replays and saves!)'
      TabOrder = 8
    end
    object chkProgFiles: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 253
      Width = 465
      Height = 17
      Hint = 'The Battle.net launcher installation folder'
      Align = alTop
      Caption = 'Delete C:\Program Files (x86)\Battle.net'
      Checked = True
      State = cbChecked
      TabOrder = 9
    end
    object chkHostsFile: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 265
      Width = 465
      Height = 17
      Hint =
        'Removes stale Blizzard / Battle.net entries from the Windows host' +
        's file (a backup is saved as hosts.bak). Off by default.'
      Align = alTop
      Caption = 'Clean hosts file (remove Blizzard / Battle.net entries)'
      TabOrder = 18
    end
    object chkResetWMI: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 276
      Width = 465
      Height = 17
      Hint = 
        'Nuclear option! Resets the Windows Management Instrumentation da' +
        'tabase. Only use this if nothing else fixes the installer. Unche' +
        'cked by default.'
      Align = alTop
      Caption = 'Reset WMI Repository (use only if installer is corrupted)'
      TabOrder = 10
    end
    object chkSecLogon: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 283
      Width = 465
      Height = 17
      Hint =
        'Battle.net requires the Windows "Secondary Logon" service. This ' +
        'sets it to Automatic and starts it.'
      Align = alTop
      Caption = 'Enable Secondary Logon service (required by Battle.net)'
      Checked = True
      State = cbChecked
      TabOrder = 19
    end
    object chkNetReset: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 289
      Width = 465
      Height = 17
      Hint =
        'Flushes DNS and resets the Winsock / TCP-IP stack to fix ISP / n' +
        'etwork routing issues. Needs a reboot. Off by default.'
      Align = alTop
      Caption = 'Reset network stack (Winsock + DNS flush) - needs reboot'
      TabOrder = 20
    end
    object chkSysRepair: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 295
      Width = 465
      Height = 17
      Hint =
        'Runs DISM + SFC to repair corrupted Windows system files. Can ta' +
        'ke 10-30 minutes; the window will look frozen. Off by default.'
      Align = alTop
      Caption = 'Repair Windows system files (SFC + DISM) - can take 30 min'
      TabOrder = 21
    end
    object chkLocaleFix: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 297
      Width = 465
      Height = 17
      Hint =
        'Sets the launcher UI language to English (enUS) in the registry.' +
        ' Use if Battle.net shows the wrong language. Does not change you' +
        'r account region. Off by default.'
      Align = alTop
      Caption = 'Force Battle.net language to English (fixes wrong-language laun' +
        'cher)'
      TabOrder = 23
    end
    object chkDownload: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 299
      Width = 465
      Height = 17
      Hint = 
        'Downloads a fresh Battle.net installer from Blizzard servers. Sk' +
        'ips download if a recent copy already exists.'
      Align = alTop
      Caption = 'Download Battle.net installer'
      Checked = True
      State = cbChecked
      TabOrder = 11
    end
    object chkRunInstaller: TCheckBox
      AlignWithMargins = True
      Left = 5
      Top = 322
      Width = 465
      Height = 17
      Hint = 
        'Automatically launches the Battle.net installer after cleanup is' +
        ' done'
      Align = alTop
      Caption = 'Run downloaded installer'
      Checked = True
      State = cbChecked
      TabOrder = 12
    end
    object btnCheckAll: TButton
      Left = 380
      Top = 324
      Width = 90
      Height = 33
      Hint = 'Select all cleanup steps'
      Anchors = [akRight]
      Caption = 'Check All'
      TabOrder = 13
      OnClick = btnCheckAllClick
    end
    object btnUncheckAll: TButton
      Left = 380
      Top = 360
      Width = 90
      Height = 33
      Hint = 'Clear all cleanup steps'
      Anchors = [akRight]
      Caption = 'Uncheck All'
      TabOrder = 22
      OnClick = btnUncheckAllClick
    end
    object btnClean: TButton
      AlignWithMargins = True
      Left = 5
      Top = 472
      Width = 465
      Height = 42
      Hint = 
        'Runs all checked cleanup steps, then downloads and launches a fr' +
        'esh Battle.net installer. All deleted folders are sent to the Re' +
        'cycle Bin.'
      Align = alBottom
      Caption = 'CLEAN && REINSTALL'
      Font.Charset = ANSI_CHARSET
      Font.Color = clWindowText
      Font.Height = -17
      Font.Name = 'Calibri'
      Font.Style = [fsBold]
      ParentFont = False
      TabOrder = 14
      OnClick = btnCleanClick
    end
    object btnKill: TButton
      Left = 397
      Top = 15
      Width = 75
      Height = 28
      Anchors = [akTop, akRight]
      Caption = 'Kill now'
      TabOrder = 15
      OnClick = btnKillClick
    end
    object Panel1: TPanel
      AlignWithMargins = True
      Left = 5
      Top = 431
      Width = 465
      Height = 35
      Align = alBottom
      BevelOuter = bvNone
      TabOrder = 17
      object lblSC2: TLabel
        AlignWithMargins = True
        Left = 3
        Top = 3
        Width = 57
        Height = 32
        Hint = 
          'StarCraft II install path detected from the registry. This is sa' +
          'ved before cleanup and can be restored afterward.'
        Align = alLeft
        Caption = 'SC2 path:'
        Layout = tlCenter
      end
      object edtSC2Path: TEdit
        AlignWithMargins = True
        Left = 66
        Top = 3
        Width = 320
        Height = 29
        Hint = 
          'StarCraft II install folder. Auto-detected from registry, or typ' +
          'e it manually. Note: Battle.net does NOT use the registry to fin' +
          'd games. After reinstalling, use Battle.net > StarCraft II > "Lo' +
          'cate the game" to point it to your SC2 folder.'
        Align = alClient
        TabOrder = 0
      end
      object btnHelpLocate: TButton
        AlignWithMargins = True
        Left = 392
        Top = 3
        Width = 70
        Height = 29
        Hint = 
          'Shows instructions on how to make Battle.net find your existing ' +
          'game installations after a clean reinstall.'
        Align = alRight
        Caption = 'Info'
        TabOrder = 1
        OnClick = btnHelpLocateClick
      end
    end
  end
